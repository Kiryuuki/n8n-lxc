# Copy to /etc/n8n/n8n.env on the Ubuntu LXC.
# Never commit real values.

N8N_VERSION=2.19.4
N8N_HOST=dok-neyn.kiryuuki.space
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://dok-neyn.kiryuuki.space
WEBHOOK_URL=https://dok-neyn.kiryuuki.space
N8N_PROXY_HOPS=1
N8N_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32

N8N_DEFAULT_TIMEOUT=900000
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=127.0.0.1
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=replace_with_generated_postgres_password

EXTERNAL_HOOK_FILES=/opt/n8n/execution-hooks.js
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace_with_rotated_supabase_key
SUPABASE_EXECUTION_LOG_TABLE=n8n_execution_logs

N8N_CUSTOM_EXTENSIONS=/opt/n8n/custom
N8N_ALLOWED_PATHS=/opt/obsidian-vault,/opt/n8n-backup,/tmp
NODE_PATH=/opt/n8n/custom/node_modules
NODE_FUNCTION_ALLOW_EXTERNAL=playwright,playwright-core
NODE_FUNCTION_ALLOW_BUILTIN=*
N8N_ENABLE_EXECUTE_COMMAND=true
NODES_EXCLUDE=[]

BROWSERLESS_WS_URL=ws://192.168.100.60:3111?token=replace_with_token&timeout=55000
PLAYWRIGHT_BROWSERS_PATH=/opt/n8n/ms-playwright
